{
  "name": "k-drama-watchlist-server",
  "version": "0.1.0",
  "description": "NestJS API for Drama Watch",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.22.1",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@better-auth/mongo-adapter": "^1.6.23",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.28",
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "better-auth": "^1.6.23",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mongodb": "~7.2.0",
    "mongoose": "^9.7.4",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.1",
    "eslint": "^9.39.5",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
