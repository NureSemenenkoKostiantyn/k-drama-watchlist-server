{
  "moduleFileExtensions": ["js", "json", "ts"],
  "extensionsToTreatAsEsm": [".ts"],
  "rootDir": "..",
  "setupFiles": ["<rootDir>/test/setup-env.ts"],
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.spec.json",
        "useESM": true
      }
    ]
  }
}
